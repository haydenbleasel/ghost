    "@t3-oss/env-nextjs": "^0.13.11",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/functions": "^3.4.3",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cobe": "^2.0.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "fuse.js": "^7.3.0",
    "gamedig": "^5.3.2",
    "input-otp": "^1.4.2",
    "jose": "^6.2.2",
    "lodash.merge": "^4.6.2",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
