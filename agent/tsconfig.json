{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["bun"],
    "paths": {
      "@protocol/*": ["../protocol/*"]
    }
  },
  "include": ["src/**/*.ts", "../protocol/**/*.ts"]
}
